# Proposal Builder — live-mode config.
# Copy to .env, fill in, then load before running (nothing auto-loads it):
#     set -a; source .env; set +a
#     python cli.py --brief example_brief.txt --pipeline-url "$PB_PIPELINE_URL"

# Gemini auth — pick ONE of the two modes:
#
# (a) Vertex AI via Application Default Credentials (recommended; no key).
#     Needs `gcloud auth application-default login` once, Vertex AI API enabled
#     on the project, and roles/aiplatform.user.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# (b) Gemini Developer API key (used only when the Vertex flag is off)
GEMINI_API_KEY=

# Optional model routing (both default to gemini-2.5-flash)
PB_MODEL_CHEAP=gemini-2.5-flash    # brief extraction, section proposal, claim extraction
PB_MODEL_DRAFT=gemini-2.5-flash    # section drafting — bump for quality

# Not read by the code — convenience for the --pipeline-url flag.
# Base URL of the running chat-with-your-docs FastAPI service (POST /chat).
PB_PIPELINE_URL=http://localhost:8000
